# Discord Developer Portal
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# PostgreSQL / Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/market

# Channel where account requests are sent
ADMIN_CHANNEL_ID=

# Optional: only this role can approve/reject from buttons.
# If empty, Discord Administrator permission is required.
ADMIN_ROLE_ID=

# Optional: role IDs to manage on setup / approval / rejection.
MARKET_PENDING_ROLE_ID=
MARKET_USER_ROLE_ID=

# Optional: shown in DM after account creation.
WEBAPP_URL=http://localhost:3000
